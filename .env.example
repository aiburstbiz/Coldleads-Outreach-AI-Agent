# LLM - Gemini API (used in dev1_research/analyzer.py)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Gmail API (used in dev2_delivery/gmail_sender.py)
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here

# Database (used in dev2_delivery, graph/workflow.py for history)
DATABASE_URL=postgresql://user:password@localhost:5432/sales_agent

# App config
ENVIRONMENT=development
LOG_LEVEL=INFO
